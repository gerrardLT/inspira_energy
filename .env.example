# ─── PostgreSQL ────────────────────────────────────────────────────────────────
# 数据库连接字符串（必填）
DATABASE_URL=postgresql://user:password@localhost:5432/inspira_energy

# ─── Redis ────────────────────────────────────────────────────────────────────
# Redis 主机地址（必填）
REDIS_HOST=127.0.0.1
# Redis 端口（必填）
REDIS_PORT=6379

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
# SMTP 服务器主机（必填）
SMTP_HOST=smtp.example.com
# SMTP 服务器端口（必填）
SMTP_PORT=587
# SMTP 认证用户名（必填）
SMTP_USER=noreply@inspiraenergy.com
# SMTP 认证密码（必填）
SMTP_PASS=secret
# 发件人地址（必填）
SMTP_FROM=noreply@inspiraenergy.com

# ─── Email Recipients ─────────────────────────────────────────────────────────
# 投资者关系团队邮箱（必填）- LP/投资者表单通知路由目标
EMAIL_IR_TEAM=ir@inspiraenergy.com
# 开发团队邮箱（必填）- 开发商表单通知路由目标
EMAIL_DEV_TEAM=development@inspiraenergy.com
# 支持团队邮箱（必填）- 通用咨询表单通知路由目标
EMAIL_SUPPORT_TEAM=support@inspiraenergy.com

# ─── File Storage ─────────────────────────────────────────────────────────────
# 文件上传存储目录（必填）- 开发商表单附件存储路径
UPLOAD_DIR=G:/inspira_energy_uploads

# ─── App ──────────────────────────────────────────────────────────────────────
# CORS 允许的源（必填）- 前端域名，用于跨域请求验证
CORS_ORIGIN=https://www.inspiraenergy.com

# ─── Admin API ────────────────────────────────────────────────────────────────
# 管理 API 认证密钥（可选）- 未配置时管理端点返回 503
ADMIN_API_KEY=your-secure-api-key-here

# ─── Storage Backend ──────────────────────────────────────────────────────────
# 存储后端类型（可选）- 支持 "local"（本地文件系统）和 "s3"（S3 兼容对象存储）
# 未配置或无效值时自动回退到 "local"
STORAGE_BACKEND=local

# S3 兼容对象存储配置（当 STORAGE_BACKEND=s3 时必填）
# S3 服务端点 URL
S3_ENDPOINT=https://s3.amazonaws.com
# S3 存储桶名称
S3_BUCKET=inspira-energy-uploads
# S3 访问密钥 ID
S3_ACCESS_KEY=your-access-key
# S3 访问密钥 Secret
S3_SECRET_KEY=your-secret-key
# S3 区域
S3_REGION=ap-southeast-1

# ─── Webhook ──────────────────────────────────────────────────────────────────
# Webhook 通知 URL（可选）- 未配置时跳过即时通知
# 企业微信示例: https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxx
# 飞书示例: https://open.feishu.cn/open-apis/bot/v2/hook/xxx
# Slack 示例: https://hooks.slack.com/services/xxx/xxx/xxx
WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxx
# Webhook 目标平台（当 WEBHOOK_URL 已配置时必填）- 支持 wechat/feishu/slack
WEBHOOK_PLATFORM=wechat
